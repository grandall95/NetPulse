<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer Wi-Fi Wave Arch -->
    <path
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 33,40 Q 54,20 75,40">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="33"
                android:startY="30"
                android:endX="75"
                android:endY="30">
                <item android:offset="0.0" android:color="#00F2FE" /> <!-- Bright Electric Cyan -->
                <item android:offset="1.0" android:color="#00FD9A" /> <!-- Vibrant Pulse Green -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Wi-Fi Wave Arch -->
    <path
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M 43,48 Q 54,37 65,48">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="43"
                android:startY="42"
                android:endX="65"
                android:endY="42">
                <item android:offset="0.0" android:color="#00F2FE" />
                <item android:offset="1.0" android:color="#00FD9A" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Network Pulse Heartbeat Line -->
    <path
        android:strokeWidth="4.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M 24,59 L 41,59 L 45,47 L 49,71 L 54,33 L 59,65 L 63,59 L 84,59">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="24"
                android:startY="59"
                android:endX="84"
                android:endY="59">
                <item android:offset="0.0" android:color="#00F2FE" />
                <item android:offset="1.0" android:color="#00FD9A" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Sleek Glow Core at Heartbeat Max Peak -->
    <path
        android:pathData="M 54,33 m -2.5,0 a 2.5,2.5 0 1,1 5,0 a 2.5,2.5 0 1,1 -5,0"
        android:fillColor="#FFFFFF" />
        
</vector>
